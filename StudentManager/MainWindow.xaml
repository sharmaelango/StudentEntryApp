<Window x:Class="StudentManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentManager"
        mc:Ignorable="d"
        Title="Student Details Manager" Height="520" Width="860"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>
        <Style x:Key="LableStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Setter Property="Margin" Value="0,8,0,3"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="White"
                CornerRadius="10"
                Padding="20"
                BorderBrush="#CBD5E0"
                BorderThickness="1">

            <StackPanel>
                <TextBlock Text="Student Entry Form"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#2B6CB0"
                           Margin="0,0,0,16"/>

                <TextBlock Text="S.No"
                           Style="{StaticResource LableStyle}"/>
                <TextBox x:Name="txtSNo"
                         Style="{StaticResource InputStyle}"
                         IsReadOnly="True"
                         Background="#EDF2F7"
                         ToolTip="Auto-generated - cannot be edited"/>

                <TextBlock Text="Student Name"
                            Style="{StaticResource LableStyle}"/>
                <TextBox x:Name="txtName"
                        Style="{StaticResource InputStyle}"
                        MaxLength="100"
                        ToolTip="Enter the full name of the student"/>

                <TextBlock Text="Class"
                           Style="{StaticResource LableStyle}"/>
                <TextBox x:Name="txtClass"
                         Style="{StaticResource InputStyle}"
                         MaxLength="20"
                         ToolTip="e.g. Grade 10, Class A"/>

                <TextBlock Text="Register Number"
                           Style="{StaticResource LableStyle}"/>
                <TextBox x:Name="txtRegNo"
                         Style="{StaticResource InputStyle}"
                         MaxLength="20"
                         ToolTip="Unique Student Register Number"/>

                <Separator Margin="0,20,0,16"
                           Background="#E2E8F0"/>


                <Button x:Name="BtnAdd"
                        Content="➕ Add Student"
                        Style="{StaticResource ButtonStyle}"
                        Background="#3182CE"
                        Margin="0,0,0,8"
                        Click="BtnAdd_Click"/>

                <Button x:Name="BtnDelete"
                        Content="🗑️ Delete Selected"
                        Style="{StaticResource ButtonStyle}"
                        Background="#E53E3E"
                        Click="BtnDelete_Click"
                        Margin="0,0,0,8"/>

                <Button x:Name="BtnClear"
                        Content="🧹 Clear Form"
                        Style="{StaticResource ButtonStyle}"
                        Background="#718096"
                        Click="BtnClear_Click"/>

                <TextBlock x:Name="txtStatus"
                           FontSize="11"
                           Foreground="#38A169"
                           TextWrapping="Wrap"
                           Margin="0,14,0,0"
                           HorizontalAlignment="Center"/>

            </StackPanel>
        </Border>

        <Border Grid.Column="2"
                Background="White"
                CornerRadius="10"
                Padding="20"
                BorderBrush="#CBD5E0"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Student Records"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#2B6CB0"
                           Margin="0,0,0,12"/>

                <DataGrid x:Name="StudentGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="1"
                          BorderBrush="#E2E8F0"
                          RowBackground="White"
                          AlternatingRowBackground="#F7FAFC"
                          ColumnHeaderHeight="38"
                          RowHeight="36"
                          FontSize="13"
                          SelectionChanged="StudentGrid_SelectionChanged">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"       Value="#EBF4FF"/>
                            <Setter Property="Foreground"       Value="#2B6CB0"/>
                            <Setter Property="FontWeight"       Value="Bold"/>
                            <Setter Property="Padding"          Value="10,0"/>
                            <Setter Property="BorderBrush"      Value="#BEE3F8"/>
                            <Setter Property="BorderThickness"  Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="S.No"
                            Binding="{Binding SNo}"
                            Width="60"/>

                        <DataGridTextColumn Header="Student Name"
                            Binding="{Binding StudentName}"
                            Width="*"/>

                        <DataGridTextColumn Header="Class"
                            Binding="{Binding Class}"
                            Width="100"/>

                        <DataGridTextColumn Header="Register Number"
                            Binding="{Binding RegisterNumber}"
                            Width="140"/>
                    </DataGrid.Columns>

                </DataGrid>

            </Grid>
        </Border>
    </Grid>

</Window>
